LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_preferred_model

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxx.mongodb.net/linebot

NEXT_PUBLIC_APP_URL=...

# Mem0 Memory Configuration
MEMORY_PROVIDER=mem0_oss
# Qdrant Vector Store (leave empty to use in-memory store for dev)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# Or use Qdrant Cloud
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key
# Mem0 LLM model for memory extraction (uses OpenAI API key above)
# MEM0_LLM_MODEL=gpt-4.1-nano