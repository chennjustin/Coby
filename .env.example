LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_preferred_model

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxx.mongodb.net/linebot

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# =============================================================================
# Mem0 長期記憶（需與上方 OPENAI_API_KEY 共用，用於 embedding + 記憶萃取）
# =============================================================================
MEMORY_PROVIDER=mem0_oss

# -----------------------------------------------------------------------------
# Qdrant：請申請「Qdrant Cloud」免費方案（不是自架 Docker，除非你本機開發）
#
# 步驟：
# 1. 開 https://cloud.qdrant.io 註冊 / 登入
# 2. Create cluster → 選 Free tier
# 3. 進入該 cluster → 複製 Cluster URL（形如 https://xxxx.region.cloud.qdrant.io）
# 4. API Keys → 建立一組 key，複製到下方 QDRANT_API_KEY
#
# Vercel 部署：務必在 Vercel 專案 Settings → Environment Variables 填入
# QDRANT_URL、QDRANT_API_KEY、MEMORY_PROVIDER（與本機 .env.local 相同概念）
# -----------------------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# -----------------------------------------------------------------------------
# 本機開發（二選一）：
#
# A) 有填 QDRANT_URL + QDRANT_API_KEY → 與雲端同一套，記憶與線上一致
#
# B) 不想用雲端時，可改用本機 Docker Qdrant（專案根目錄 docker compose up -d）：
#    註解掉 QDRANT_URL / QDRANT_API_KEY，改設：
#    QDRANT_HOST=localhost
#    QDRANT_PORT=6333
#
# C) 兩者都不設 → 使用 in-memory 向量（僅方便快速試跑，重啟後記憶消失）
# -----------------------------------------------------------------------------

# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Mem0 內部用來「萃取記憶」的 LLM（可與 OPENAI_MODEL 不同，建議便宜小模型）
# MEM0_LLM_MODEL=gpt-4.1-nano

# 僅本機：Mem0 SQLite 歷史檔路徑（Vercel 會自動停用，改靠 MongoDB SavedItem）
# MEM0_HISTORY_DB_PATH=mem0_history.db
